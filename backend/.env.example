# Required environment variables for the backend

# Your Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# The Vercel frontend URL (used for CORS). Include https://, no trailing slash.
# Example: https://nisha-kumari-portfolio.vercel.app
ALLOWED_ORIGIN=https://your-vercel-app.vercel.app

# Port (Render sets this automatically — do not change for production)
PORT=5000
